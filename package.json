{
  "name": "titan",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "description": "TITAN — Social Media Marketing Intelligence Dashboard",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/copy-data-to-public.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "scrape:ig": "node scripts/scrape-ig.mjs",
    "scrape:tt": "node scripts/scrape-tt.mjs",
    "scrape:ig:enrich": "node scripts/scrape-ig.mjs --force",
    "scrape:tt:force": "node scripts/scrape-tt.mjs --force",
    "scrape:full": "node scripts/scrape-ig.mjs && node scripts/scrape-tt.mjs",
    "validate": "node scripts/validate-merge.mjs",
    "generate": "node scripts/generate-data.mjs",
    "insights:generate": "node scripts/generate-ai-insights.mjs",
    "insights:briefing": "node scripts/generate-ai-insights.mjs briefing=1",
    "pipeline": "node scripts/scrape-ig.mjs && node scripts/scrape-tt.mjs && node scripts/validate-merge.mjs && node scripts/generate-data.mjs",
    "test": "vitest run",
    "deploy": "node scripts/deploy.mjs",
    "deploy:dry": "node scripts/deploy.mjs --dry-run",
    "deploy:nopush": "node scripts/deploy.mjs --skip-push",
    "setup:audit-infra": "bash scripts/hooks/install-audit-infra.sh",
    "audit:pre-session": "node scripts/hooks/pre-session.cjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.13.0",
    "lucide-react": "^0.453.0",
    "framer-motion": "^11.11.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2",
    "dotenv": "^16.4.5"
  }
}
