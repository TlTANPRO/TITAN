# =============================================================
# TITAN — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================

# -------------------------------------------------------------
# ENSEMBLEDATA API (scraper only — not used by the deployed app)
# -------------------------------------------------------------
# Pool of 26 tokens. The scraper rotates them and skips 495
# (quota-exhausted) responses. Set ENSEMBLEDATA_TOKENS_FILTER
# to use only a known-good subset (comma-separated prefixes).
ENSEMBLEDATA_TOKENS=token1,token2,token3
ENSEMBLEDATA_DAILY_PING=true
# Optional: comma-separated prefix list to use only known-working tokens
# ENSEMBLEDATA_TOKENS_FILTER=GXQv,rntd,nfj8

# -------------------------------------------------------------
# LLM Provider (used by the scraper / dev mode only)
# -------------------------------------------------------------
VITE_LLM_PROVIDER=openrouter
VITE_LLM_MODEL=anthropic/claude-3-haiku

# -------------------------------------------------------------
# Web access (free public CORS proxy — no setup required)
# -------------------------------------------------------------
VITE_WEB_ACCESS_PROXY=https://api.allorigins.win/raw?url=

# -------------------------------------------------------------
# Build config
# -------------------------------------------------------------
VITE_APP_NAME=TITAN
VITE_BASE_PATH=/TITAN/

# -------------------------------------------------------------
# Cloudflare Worker LLM proxy — RECOMMENDED for production
# -------------------------------------------------------------
# When set, the app runs in FULL-AUTO mode: zero user input,
# API keys live encrypted in the Worker (never in the browser).
#
# Deploy the proxy once via Cloudflare Dashboard:
#   1. https://dash.cloudflare.com → Workers & Pages → Create
#   2. Start with "Hello World", name it titan-llm-proxy
#   3. Edit Code → paste cloudflare-worker/src/index.js → Deploy
#   4. Settings → Variables → add OPENROUTER_API_KEY + GOOGLE_STUDIO_API_KEY
#      (Type: Secret/encrypted, NOT Plaintext)
#   5. Copy the Worker URL from Settings → Triggers
#   6. Paste it here, then `pnpm build` and push
#
# Without this line, the app is in DIRECT mode and would prompt
# the user to enter API keys in Settings (not implemented — use
# the proxy instead).
# -------------------------------------------------------------
VITE_LLM_PROXY_URL=https://titan-llm-proxy.YOUR-SUBDOMAIN.workers.dev
