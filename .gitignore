# dependencies
node_modules/
.pnpm-store/

# build output
dist/
dist-ssr/
*.local

# env (NEVER commit secrets)
.env
.env.local
.env.production
.env.development.local
.env.test.local

# scraped data (large JSON, regenerated by scraper)
scripts/scraped/
scripts/scraped-15jul-backup/
# V29.1 audit snapshots (ad-hoc backups, never commit)
scripts/.snapshot-*/
scripts/.snapshot-*.json
scripts/.scrape-ig-*.log
scripts/.diff-v291.mjs
# token validation (may contain sensitive metadata, regenerated)
scripts/_test/
scripts/token-validation-*.json
# V27.16: ENSEMBLEDATA token pool for validate-tokens-now.mjs
# (list of API tokens, NEVER commit — must be local-only)
scripts/.token-pool.json
# generated reports (regenerated on demand)
scripts/report-*.md

# generated data
src/data/accounts-full.json
# prebuild copy (vite will copy to dist/data/ anyway)
public/data/accounts-full.json

# logs
*.log
npm-debug.log*
pnpm-debug.log*

# editor
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# pwa
dev-dist/

# backup (temporary, for safe pre-simplify rollback)
BACKUP-*/

# deploy-generated root files (rebuilt by scripts/deploy.mjs from dist/)
# These ARE committed to git because gh-pages serves from root, but
# the canonical source is dist/. If you need to rebuild, run `pnpm run deploy`.
# (kept tracked intentionally — see scripts/deploy.mjs)
